{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "quantaex-cron",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-20",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "quantaex-production",
      "database_id": "5eb4f183-1dfc-4310-8872-07b014078dbc"
    }
  ],
  "vars": {}
}
