{
  "name": "quantaex",
  "version": "1.0.0",
  "type": "module",
  "description": "QuantaEX - Full-featured cryptocurrency exchange platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite --mode development",
    "dev:pages": "wrangler pages dev dist --d1=quantaex-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build --mode client && vite build",
    "preview": "wrangler pages dev dist --local",
    "deploy": "npm run build && wrangler pages deploy dist --project-name quantaex",
    "db:migrate:local": "wrangler d1 migrations apply quantaex-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply quantaex-production --remote"
  },
  "dependencies": {
    "@noble/post-quantum": "^0.6.1",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "hono": "^4.7.0",
    "lightweight-charts": "^4.2.2",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.25.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^11.8.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "postcss": "^8.4.49",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.3",
    "uuid": "^11.0.5",
    "vite": "^6.0.7",
    "wrangler": "^4.4.0"
  }
}
